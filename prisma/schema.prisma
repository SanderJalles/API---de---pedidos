// Configuração do Banco de Dados
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Tabela de Pedidos (Formatada conforme o requisito de mapping)
model Order {
  id           Int      @id @default(autoincrement())
  orderId      String   @unique // O "numeroPedido" transformado
  value        Float    // O "valorTotal" transformado
  creationDate DateTime // A "dataCriacao" transformada
  items        Item[]
}

// Tabela de Itens do Pedido
model Item {
  id        Int    @id @default(autoincrement())
  productId Int    // O "idItem" transformado
  quantity  Int    // A "quantidadeltem" transformada
  price     Float  // O "valorltem" transformado
  order     Order  @relation(fields: [orderId], references: [orderId])
  orderId   String
}